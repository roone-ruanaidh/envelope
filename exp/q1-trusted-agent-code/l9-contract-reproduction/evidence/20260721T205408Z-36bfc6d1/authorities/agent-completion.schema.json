{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completion": {
      "anyOf": [
        {
          "additionalProperties": false,
          "properties": {
            "service_command": {
              "items": {
                "maxLength": 8192,
                "type": "string"
              },
              "maxItems": 128,
              "minItems": 1,
              "type": "array"
            },
            "status": {
              "const": "declared_complete"
            }
          },
          "required": [
            "status",
            "service_command"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "maxLength": 1048576,
              "minLength": 1,
              "type": "string"
            },
            "status": {
              "const": "blocked"
            }
          },
          "required": [
            "status",
            "reason"
          ],
          "type": "object"
        }
      ]
    }
  },
  "required": [
    "completion"
  ],
  "type": "object"
}
